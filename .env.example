# ═══════════════════════════════════════════════════════════
# GuessMyPlace (GMP) v2.0.0 — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env
# ═══════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Supabase ────────────────────────────────────────────────
# Get these from: supabase.com → Your Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Firebase ────────────────────────────────────────────────
# Get from: console.firebase.google.com → Project Settings
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com/
FIREBASE_API_KEY=AIzaSy...
FIREBASE_PROJECT_ID=your-project-id
# Admin SDK JSON as single line string (for server-side auth)
FIREBASE_ADMIN_SDK_JSON={"type":"service_account","project_id":"..."}

# ── Redis ────────────────────────────────────────────────────
# Free option: upstash.com → Create Redis → copy URL
REDIS_URL=redis://localhost:6379

# ── Gemini (AtlasMind data generation) ──────────────────────
# Get from: aistudio.google.com → Get API Key
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.5-pro

# ── Atlas Engine Config ──────────────────────────────────────
ATLAS_EMBEDDING_MODEL=all-MiniLM-L6-v2
ATLAS_CONFIDENCE_STAGE_1=99.0
ATLAS_CONFIDENCE_STAGE_2=95.0
ATLAS_CONFIDENCE_STAGE_3=88.0
ATLAS_CONFIDENCE_STAGE_4=78.0
ATLAS_FORCE_GUESS_AT_ITEMS=2